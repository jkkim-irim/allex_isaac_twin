{
    "node_name": "isaac_sim_integrated_ros2",
    "bridge_extension": "isaacsim.ros2.bridge",
    "default_domain_id": 77,
    "default_rmw_implementation": "rmw_cyclonedds_cpp",
    "init_timeout": 5.0,
    "shutdown_timeout": 1.0,
    "thread_daemon": true,
    "executor_timeout": 0.1,

    "qos": {
        "history_depth": 10
    },

    "topics": {
        "robot_state": "/robot_state"
    },

    "topic_mode": {
        "current": "joint_positions_deg",
        "desired": "joint_ang_target_deg",
        "default": "joint_positions_deg",
        "display_names": {
            "joint_positions_deg": "Current",
            "joint_ang_target_deg": "Desired"
        }
    },

    "_joint_indices_doc": "indices 는 src/allex/config/joint_config.json::joint_names (ground truth) 와 src/allex/trajectory_generate/joint_name_map.py::ALLEX_CSV_JOINT_NAMES 의 매핑을 따른다. Hand 는 column-major (L11..L51 = 5 finger 의 1번째 joint, L12..L52 = 2번째, L13..L53 = 3번째). Thumb 1/2/3 = Yaw/CMC/MCP, 다른 finger 1/2/3 = ABAD/MCP/PIP. DIP/IP 는 follower (equality 로 자동 종속) 라 ROS2 미전송. WP = Waist_Lower_Pitch (joint_name_map theOne_waist 기준).",
    "joint_groups": {
        "right_hand": {
            "indices": [40, 44, 48, 52, 56,  41, 45, 49, 53, 57,  42, 46, 50, 54, 58],
            "names":   ["R11", "R21", "R31", "R41", "R51",
                        "R12", "R22", "R32", "R42", "R52",
                        "R13", "R23", "R33", "R43", "R53"]
        },
        "left_hand": {
            "indices": [13, 17, 21, 25, 29,  14, 18, 22, 26, 30,  15, 19, 23, 27, 31],
            "names":   ["L11", "L21", "L31", "L41", "L51",
                        "L12", "L22", "L32", "L42", "L52",
                        "L13", "L23", "L33", "L43", "L53"]
        },
        "right_arm": {
            "indices": [33, 34, 35, 36, 37, 38, 39],
            "names":   ["RSP", "RSR", "RSY", "REP", "RWY", "RWR", "RWP"]
        },
        "left_arm": {
            "indices": [6, 7, 8, 9, 10, 11, 12],
            "names":   ["LSP", "LSR", "LSY", "LEP", "LWY", "LWR", "LWP"]
        },
        "waist": {
            "indices": [0, 2],
            "names":   ["WY", "WP"]
        },
        "neck": {
            "indices": [4, 5],
            "names":   ["NP", "NY"]
        }
    },

    "outbound_topic_to_joints": {
        "Arm_R_theOne":      ["RSP", "RSR", "RSY", "REP", "RWY", "RWR", "RWP"],
        "Hand_R_thumb_wir":  ["R11", "R12", "R13"],
        "Hand_R_index_wir":  ["R21", "R22", "R23"],
        "Hand_R_middle_wir": ["R31", "R32", "R33"],
        "Hand_R_ring_wir":   ["R41", "R42", "R43"],
        "Hand_R_little_wir": ["R51", "R52", "R53"],
        "Arm_L_theOne":      ["LSP", "LSR", "LSY", "LEP", "LWY", "LWR", "LWP"],
        "Hand_L_thumb_wir":  ["L11", "L12", "L13"],
        "Hand_L_index_wir":  ["L21", "L22", "L23"],
