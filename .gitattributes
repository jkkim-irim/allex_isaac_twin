# Git LFS — track binary / large assets via Large File Storage.
#
# Local setup (one-time, per developer):
#     sudo apt install git-lfs        # or brew install git-lfs
#     git lfs install                 # registers filter in ~/.gitconfig
#
# After installing, files matching the patterns below are stored as
# pointers in git (~130 B each) while the actual blobs live on the LFS
# server. `git clone` automatically downloads them.
#
# To migrate already-committed files into LFS (one-time, dangerous —
# rewrites history):
#     git lfs migrate import --include="*.usd,*.stl"

# USD scene + hand model (~45 MB each, MJCF imported binary)
*.usd filter=lfs diff=lfs merge=lfs -text
*.usda filter=lfs diff=lfs merge=lfs -text
*.usdc filter=lfs diff=lfs merge=lfs -text

# STL meshes — collision/visual geometry, ~1 MB each, dozens of files
*.stl filter=lfs diff=lfs merge=lfs -text

# rosbag2 / mcap raw data (data/ already in .gitignore but pattern kept
# in case rosbag samples are ever added under repo root for examples)
*.mcap filter=lfs diff=lfs merge=lfs -text
*.bag filter=lfs diff=lfs merge=lfs -text

# Large reference CSVs (e.g. trajectory/*/real_data/*.csv > 10 MB).
# Smaller via-point trajectory CSVs (< 1 MB) stay in regular git.
trajectory/**/real_data/*.csv filter=lfs diff=lfs merge=lfs -text
